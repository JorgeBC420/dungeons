; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="Calabozos: Guerra de Facciones"
config/description="A two-player card battle game featuring three factions: Humans, Orcs, and Elves"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.0", "4.1")
config/icon="res://icon.svg"

[android]

package/unique_name="com.calabozos.guerrafacciones"
package/name="Calabozos"
permissions=PackedStringArray("INTERNET", "ACCESS_NETWORK_STATE", "BILLING")
version/code=1
version/name="1.0"
min_sdk=21
target_sdk=31
orientation="portrait"
xr_features/xr_mode=0

[android/gradle_dependencies]

custom_maven_repositories=PackedStringArray()
dependencies=PackedStringArray()

[input]

[localization]

translations=PackedStringArray()
locale_filter=[0, ["es", "en", "pt"]]
translation_remaps={}

[debug]

gdscript/warnings/unused_variable=1
gdscript/warnings/unused_signal=1
gdscript/warnings/unused_class_variable=1

